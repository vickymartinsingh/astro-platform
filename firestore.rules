rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }
    // True when the caller's own users doc has role == 'admin'.
    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.role == 'admin';
    }

    // users: a user reads/writes own record; wallet, role, status,
    // userCode, isBlocked all stay immutable from the client.
    //
    // OPERATOR REPORT (2026-06-06): "Balance is showing zero to the
    // user, kindly check user was having a balance but now its
    // showing 0 wallet. This is happening many times to multiple
    // users." Diagnosis: customer apps on legacy builds were
    // overwriting users/{uid}.wallet -> 0 via the merge-creation
    // race in shared/services/userService.js ensureUserDoc. Even
    // after that source bug was fixed (commit e7a5212) the previous
    // rules allowed ANY signed-in self-write to wallet so old
    // installs kept doing the wipe. These rules now reject any
    // self-write that changes wallet / role / status / userCode /
    // isBlocked so the legacy clients are blocked at the rule
    // boundary instead of being trusted to write correctly. All
    // legitimate wallet writes already go through admin-role paths
    // (relay admin SDK, adminService.adjustWallet) which match
    // isAdmin().
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid) || isAdmin();
      // Phone also locked from self-writes once it holds a real value
      // (operator report 2026-06-06: "user cannot register or delete
      // the mobile number from the account"). A one-time fill is
      // allowed when the stored phone is empty/missing so signupUser
      // can land the captured phone the very first time.
      allow update: if isAdmin()
        || (isSelf(uid)
          && (!('wallet' in request.resource.data)
            || request.resource.data.wallet == resource.data.wallet)
          && (!('role' in request.resource.data)
            || request.resource.data.role == resource.data.role)
          && (!('status' in request.resource.data)
            || request.resource.data.status == resource.data.status)
          && (!('userCode' in request.resource.data)
            || request.resource.data.userCode == resource.data.userCode)
          && (!('isBlocked' in request.resource.data)
            || request.resource.data.isBlocked == resource.data.isBlocked)
          && (!('phone' in request.resource.data)
            || !('phone' in resource.data)
            || resource.data.phone == null
            || resource.data.phone == ''
            || request.resource.data.phone == resource.data.phone));
      allow delete: if isAdmin();
    }

    // transactions: every wallet change still writes a transaction
    // (Hard Rule 6). Client-side settlement needs signed-in create.
    match /transactions/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /payments/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // astrologers: anyone reads; the astrologer updates own profile
    // (not earnings/rating/approved); an admin may update anything.
    // DEMO MODE: the astrologer settles their own earnings client-side
    // on session end (no Cloud Function). Owner (doc id == uid) or admin
    // may write fully; other signed-in users may only touch
    // rating/reviewsCount (client review recompute).
    match /astrologers/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isAdmin() || isSelf(id) ||
        (signedIn()
          && request.resource.data.earnings == resource.data.earnings
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();

      // Edit history (Phase E) - every mutation that goes through
      // payoutService.updateBank / setKyc / restoreField snapshots
      // before+after here so admin can audit + restore. Read is
      // admin-only (compliance) or the astrologer themselves.
      match /history/{hid} {
        allow read: if isAdmin() || isSelf(id);
        allow create: if isAdmin() || isSelf(id);
        allow update, delete: if false;
      }
    }

    match /sessions/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if signedIn();
      match /messages/{msgId} {
        allow read, write: if signedIn();
      }
    }

    match /kundliProfiles/{id} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /favorites/{uid} {
      allow read, write: if isSelf(uid);
    }

    match /notifications/{id} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /payouts/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /horoscope/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // settings: world-readable; admin may write (Cloud Function in prod).
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /logs/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // Audit trail (push-relay/api/audit.js writes here for every
    // signed-in login / signup / route / admin action). Reads are
    // admin-only - this is the compliance source of truth and must
    // not be visible to the customer / astrologer apps. Writes are
    // server-only (relay uses the Admin SDK and bypasses rules) so
    // we explicitly forbid client writes.
    match /audits/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
    // Kundli PDF orders. Written by the relay (admin SDK, bypasses
    // rules) under users/{uid}/orders/{orderId}. Two read paths:
    //   1) Customer reads their own orders from /orders + /kundli.
    //   2) Admin uses collectionGroup('orders') on /admin-orders.
    // A single recursive wildcard match covers both - the
    // collectionGroup query requires the rule to live at this
    // path shape. Without it the admin page silently returned 0
    // for all 207 paid orders. Writes stay admin-only because all
    // real writes flow through the relay.
    match /{document=**}/orders/{orderId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    match /reports/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /disputes/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    match /scheduler/{id} { allow read, write: if isAdmin(); }

    // Live join-request handshake (liveService.requestJoinLive +
    // accept/decline lifecycle, 2026-06-07). The viewer creates the
    // doc when they tap Live call; the astrologer + viewer both
    // update its status. We keep create open to any signed-in user
    // (rule: only their own userId), and updates open to either the
    // astrologer (astroUid matches) or the user (userId matches).
    match /liveRequests/{rid} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() &&
        (resource.data.astroUid == request.auth.uid
          || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Live-stream audience bots. The astrologer client reads the
    // pool + question list while broadcasting (to pick a random bot
    // + question per tick) and writes the resulting bot join /
    // comment events into chats/live_{uid}/messages. Pool + question
    // mutations are admin-only; reads are open to any signed-in user.
    match /liveBots/{botId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /liveBotQuestions/{qid} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    // Waitlist intents from the Discover "coming soon" flow.
    match /waitlist/{wid} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
