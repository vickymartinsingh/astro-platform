{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "client-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=client-web"],
      "port": 3000
    },
    {
      "name": "client-export",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-s", "client-web/out", "-l", "4173"],
      "port": 4173
    },
    {
      "name": "admin-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=admin-web"],
      "port": 3002
    }
  ]
}
