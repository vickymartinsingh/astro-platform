{
  "appId": "com.astroseer.mobile",
  "appName": "AstroSeer Connect",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.firebaseapp.com",
      "astrology-2092d.firebaseapp.com",
      "accounts.google.com",
      "*.google.com",
      "apis.google.com",
      "*.googleapis.com"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": false,
      "backgroundColor": "#1A0F0F",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "CapacitorUpdater": {
      "autoUpdate": true,
      "autoDeleteFailed": true,
      "autoDeletePrevious": true,
      "resetWhenUpdate": false,
      "updateUrl": "https://firebasestorage.googleapis.com/v0/b/astrology-2092d.firebasestorage.app/o/ota%2Fcustomer%2Fmanifest.json?alt=media"
    },
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com"]
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "402763204723-1f0mff93i07o9i481eg2u24mk43si5t6.apps.googleusercontent.com",
      "clientId": "402763204723-1f0mff93i07o9i481eg2u24mk43si5t6.apps.googleusercontent.com",
      "forceCodeForRefreshToken": false
    }
  }
}
