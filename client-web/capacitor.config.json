{
  "appId": "com.astroseer.mobile",
  "appName": "AstroSeer Connect",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.firebaseapp.com",
      "astrology-2092d.firebaseapp.com",
      "accounts.google.com",
      "*.google.com",
      "apis.google.com",
      "*.googleapis.com"
    ]
  },
  "plugins": {
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com"]
    }
  }
}
