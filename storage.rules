rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos, media: signed-in users may upload to their own folder.
    match /profileImages/{uid}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /media/{file=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // In-chat shared photos (sent via the "+" Choose Picture sheet).
    match /chat/{chatId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /reports/{file=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /translations/{file=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
